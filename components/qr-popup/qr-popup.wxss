/* 二维码弹窗样式 */
.qr-popup {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.6);
}

.popup-content {
  position: relative;
  width: 600rpx;
  background-color: #F5F0E1;
  border: 6rpx solid #8B4513;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.popup-header {
  margin-bottom: 30rpx;
}

.title {
  color: #8B4513;
  font-size: 36rpx;
  font-weight: bold;
}

.qr-container {
  width: 400rpx;
  height: 400rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #D4A574;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.qr-image {
  width: 360rpx;
  height: 360rpx;
}

.reward-desc {
  margin-bottom: 30rpx;
  padding: 15rpx 30rpx;
  background-color: #E8DCC8;
  border-radius: 8rpx;
}

.reward-desc text {
  color: #4A3728;
  font-size: 26rpx;
}

.close-btn {
  width: 200rpx;
  height: 70rpx;
  background-color: #8B4513;
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-btn text {
  color: #F5F0E1;
  font-size: 28rpx;
  font-weight: bold;
}
