/* 对话框样式 */
.dialog-box {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.dialog-content {
  width: 90%;
  background-color: #F5F0E1;
  border: 4rpx solid #8B4513;
  border-radius: 16rpx;
  margin-bottom: 120rpx;
  overflow: hidden;
}

.dialog-header {
  background-color: #8B4513;
  padding: 20rpx 30rpx;
}

.npc-name {
  color: #F5F0E1;
  font-size: 32rpx;
  font-weight: bold;
}

.dialog-body {
  padding: 30rpx;
  min-height: 120rpx;
}

.dialog-text {
  color: #4A3728;
  font-size: 28rpx;
  line-height: 1.6;
}

.dialog-footer {
  padding: 20rpx 30rpx;
  background-color: #E8DCC8;
  text-align: center;
}

.continue-hint {
  color: #8B4513;
  font-size: 24rpx;
}
