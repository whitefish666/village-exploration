/* 村庄介绍页面样式 */
.container {
  width: 100%;
  height: 100vh;
  background: linear-gradient(135deg, #E8DCC8 0%, #F5F0E1 50%, #D4C4A8 100%);
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 顶部标题栏 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #8B4513;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.subtitle {
  font-size: 24rpx;
  color: #6B5344;
  margin-top: 8rpx;
}

/* 内容区域 */
.content {
  flex: 1;
  padding: 10rpx 0;
}

/* 区块 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #5D4037;
  margin-bottom: 15rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #8B4513;
}

/* 卡片 */
.card {
  background-color: rgba(255, 255, 255, 0.85);
  padding: 30rpx;
  border-radius: 16rpx;
  border: 2rpx solid #D4C4A8;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.1);
}

.card-text {
  font-size: 28rpx;
  color: #4A3728;
  line-height: 1.6;
}

.cards-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.card.small {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 25rpx 15rpx;
}

.card-icon {
  font-size: 50rpx;
  margin-bottom: 10rpx;
}

.card-label {
  font-size: 24rpx;
  color: #5D4037;
  text-align: center;
}

/* 底部导航 */
.bottom-bar {
  display: flex;
  justify-content: flex-start;
  padding-top: 15rpx;
  border-top: 1rpx solid #D4C4A8;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 15rpx 30rpx;
  background-color: rgba(139, 69, 19, 0.15);
  border-radius: 30rpx;
}

.back-icon {
  font-size: 32rpx;
  color: #8B4513;
}

.back-text {
  font-size: 28rpx;
  color: #8B4513;
}
