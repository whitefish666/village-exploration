/* 首页样式 - 横板布局 */
.container {
  width: 100%;
  height: 100vh;
  background: linear-gradient(135deg, #E8DCC8 0%, #F5F0E1 50%, #D4C4A8 100%);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding: 0 60rpx;
  box-sizing: border-box;
}

/* 左侧区域 */
.left-section {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  width: 300rpx;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #8B4513;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1);
  letter-spacing: 4rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #6B5344;
  margin-top: 12rpx;
}

.profile-section {
  background-color: rgba(255, 255, 255, 0.7);
  padding: 30rpx;
  border-radius: 20rpx;
  border: 2rpx solid #D4C4A8;
}

.welcome-text {
  display: block;
  font-size: 30rpx;
  color: #4A3728;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.desc-text {
  display: block;
  font-size: 24rpx;
  color: #8B7355;
}

/* 中间区域 */
.center-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.game-entry {
  display: flex;
  justify-content: center;
  align-items: center;
}

.entry-btn {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 10rpx 40rpx rgba(139, 69, 19, 0.3);
}

.start-btn {
  background: linear-gradient(145deg, #8B4513, #A0522D);
}

.btn-icon {
  font-size: 80rpx;
  margin-bottom: 10rpx;
}

.btn-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 右侧区域 */
.right-section {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.menu-section {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.menu-item {
  width: 150rpx;
  height: 150rpx;
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.15);
  border: 2rpx solid #D4C4A8;
}

.menu-icon {
  font-size: 50rpx;
  margin-bottom: 10rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #4A3728;
}

/* 底部 */
.footer {
  position: absolute;
  bottom: 30rpx;
  left: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.version {
  font-size: 24rpx;
  color: #8B7355;
}

.tips {
  font-size: 22rpx;
  color: #A89080;
  background-color: rgba(139, 69, 19, 0.08);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}
